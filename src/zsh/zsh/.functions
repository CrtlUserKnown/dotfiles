#!/usr/bin/env zsh
# zsh functions
# Author: CrtlUserUnknown

# --- functions:devUx ---
function commands() {
    if [[ "$1" == "custom" ]]; then
        typeset -A categories
        categories=(
            "Navigation"   "cls:clear the terminal|ls:eza with color|la:eza all files with icons|ll:eza list with icons|y:yazi|f:fzf|b:btop"
            "Shell"        "reload:source ~/.zshrc|mux:tmux|lz:lazygit"
            "Python"       "py:python3|ipy:ipython3"
            "Swift"        "swiftinit:swift package init|sps:swift package show-dependencies|spt:swift package test"
            "Java"         "jv:java|jc:javac"
            "Rust"         "rn:rustc|cr:cargo run"
            "Functions"    "commands:list all commands|config:edit config files|create:scaffold a new project|attach:attach to a tmux session|duplicate:duplicate a file or folder|download:download a file"
        )

        local order=("Navigation" "Shell" "Python" "Swift" "Java" "Rust" "Functions")

        for category in "${order[@]}"; do
            echo "\n\033[1;35m[$category]\033[0m"
            local entries=(${(s:|:)categories[$category]})
            for entry in "${entries[@]}"; do
                local cmd="${entry%%:*}"
                local desc="${entry#*:}"
                printf "  \033[1;36m%-14s\033[0m %s\n" "$cmd" "$desc"
            done
        done

    else
        # collect all system commands from PATH
        local all_cmds
        all_cmds=$(echo $PATH | tr ':' '\n' | while read dir; do
            CLICOLOR=0 command ls "$dir" 2>/dev/null
        done | sort -u | grep -v '/' | grep -v '@')

        if [[ -n "$1" ]]; then
            echo "$all_cmds" | grep "$1" | column -c $(tput cols)
        else
            echo "$all_cmds" | fzf \
                --prompt="commands > " \
                --height=50% \
                --layout=reverse \
                --border \
                --preview="man {} 2>/dev/null | head -20 || echo 'no man page available'" \
                --preview-window=right:50%
        fi
    fi
}

function config() {
    if [[ -z "$1" ]]; then
        echo "Select configuration to edit:"
        select option in "Terminal/ZSH" "Tmux" "Ghostty" "Aliases" "Cancel"; do
            case "$option" in
                "Terminal/ZSH") ${EDITOR:-nvim} ~/development/dots/src/zsh/; break;;
                "Tmux") ${EDITOR:-nvim} ~/development/dots/src/tmux/tmux.conf; break;;
                "Ghostty") ${EDITOR:-nvim} ~/development/dots/src/ghostty/config; break;;
                "Aliases") ${EDITOR:-nvim} ~/development/dots/src/zsh/zsh/.aliases; break;;
                "Cancel") return 0;;
            esac
        done
    else
        case "$1" in
            terminal|zsh) ${EDITOR:-nvim} ~/development/dots/src/zsh/;;
            tmux|mux) ${EDITOR:-nvim} ~/development/dots/src/tmux/tmux.conf;;
            ghostty|ghost) ${EDITOR:-nvim} ~/development/dots/src/ghostty/config;;
            alias|aliases) ${EDITOR:-nvim} ~/development/dots/src/zsh/zsh/.aliases;;
            *) echo "Unknown config type: $1"; return 1;;
        esac
    fi
}

function create() {
    if [[ -z "$1" ]]; then
        echo "Create projects for Github and different programming languages:"
        select option in "Swift" "Java/Maven" "Rust/Cargo" "Crystal" "Git" "Cancel"; do
            case "$option" in
                "Swift")
                    read "project_name?Enter project name: "
                    mkdir -p "$project_name" && cd "$project_name"
                    swift package init
                    git init
                    break;;
                "Java/Maven")
                    read "project_name?Enter project name: "
                    mvn archetype:generate -DgroupId=com.example -DartifactId="$project_name" -DarchetypeArtifactId=maven-archetype-quickstart -DinteractiveMode=false
                    cd "$project_name"
                    git init
                    break;;
                "Rust/Cargo")
                    read "project_name?Enter project name: "
                    cargo new "$project_name"
                    cd "$project_name"
                    git init
                    break;;
                "Crystal")
                    read "project_name?Enter project name: "
                    crystal init app "$project_name"
                    cd "$project_name"
                    git init
                    break;;
                "Git")
                    read "project_name?Enter project name: "
                    mkdir -p "$project_name" && cd "$project_name"
                    git init
                    touch README.md
                    break;;
                "Cancel") return 0;;
            esac
        done
    else
        project_name="$2"
        if [[ -z "$project_name" ]]; then
            echo "Error: Please provide a project name"
            echo "Usage: create <language> <project_name>"
            return 1
        fi

        case "$1" in
            Swift|swift)
                mkdir -p "$project_name" && cd "$project_name"
                swift package init
                git init
                ;;
            Java|java|Maven|maven)
                mvn archetype:generate -DgroupId=com.example -DartifactId="$project_name" -DarchetypeArtifactId=maven-archetype-quickstart -DinteractiveMode=false
                cd "$project_name"
                git init
                ;;
            Rust|rust|Cargo|cargo)
                cargo new "$project_name"
                cd "$project_name"
                git init
                ;;
            Crystal|crystal)
                crystal init app "$project_name"
                cd "$project_name"
                git init
                ;;
            Git|git)
                mkdir -p "$project_name" && cd "$project_name"
                git init
                touch README.md
                ;;
            *)
                echo "Unknown language: $1"
                echo "Supported languages: Swift, Java/Maven, Rust/Cargo, Crystal, Git"
                return 1
                ;;
        esac
    fi
}

function attach() {
    if tmux list-sessions &> /dev/null; then
        local session=$(tmux list-sessions | cut -d: -f1 | fzf)
        if [ -n "$session" ]; then
            tmux attach-session -t "$session"
        fi
    else
        echo "No tmux sessions found"
    fi
}

function duplicate() {
    if [ $# -eq 0 ]; then
        echo "Usage: duplicate <file_or_folder> [destination_name]"
        return 1
    fi

    local source="$1"
    local destination="$2"

    if [ ! -e "$source" ]; then
        echo "Error: '$source' does not exist"
        return 1
    fi

    if [ -z "$destination" ]; then
        local basename="${source%/}"
        local extension="${basename##*.}"
        local name="${basename%.*}"

        if [ "$basename" = "$extension" ]; then
            destination="${basename} copy"
        else
            destination="${name} copy.${extension}"
        fi
    fi

    cp -R "$source" "$destination"

    if [ $? -eq 0 ]; then
        echo "Duplicated '$source' to '$destination'"
    else
        echo "Error: Failed to duplicate '$source'"
        return 1
    fi
}

function download() {
    if whence -q curl; then
        echo "Using curl to download: $1"
        curl -L -O "$1"
    elif whence -q wget; then
        echo "Using wget to download: $1"
        wget -c --show-progress "$1"
    else
        echo "Error: Neither curl nor wget is installed." >&2
        return 1
    fi
}